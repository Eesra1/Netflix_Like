<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane minHeight="600.0" minWidth="800.0" prefHeight="680.0" prefWidth="1193.0"
            style="-fx-background-color: #141414;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.jstream.controller.SubscriberController">

    <!-- ════════════════════════════════════════════════
         LEFT — SIDEBAR  (identique aux autres pages)
    ════════════════════════════════════════════════ -->
    <left>
        <VBox minWidth="220.0" prefWidth="220.0"
              style="-fx-background-color: #1e1e1e; -fx-border-color: #2e2e2e; -fx-border-width: 0 1 0 0;"
              BorderPane.alignment="TOP_LEFT">
            <children>

                <!-- Logo -->
                <HBox alignment="CENTER_LEFT" prefHeight="64.0"
                      style="-fx-border-color: #2e2e2e; -fx-border-width: 0 0 1 0;">
                    <padding><Insets bottom="16.0" left="24.0" right="24.0" top="16.0"/></padding>
                    <children>
                        <Label text="JSTREAM" textFill="#e50914">
                            <font><Font name="System Bold" size="26.0"/></font>
                        </Label>
                    </children>
                </HBox>

                <Label style="-fx-padding: 18 14 6 14;" text="PRINCIPAL" textFill="#555555">
                    <font><Font name="System Bold" size="10.0"/></font>
                </Label>

                <!-- Dashboard -->
                <HBox alignment="CENTER_LEFT" prefHeight="42.0" spacing="10.0"
                      style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <padding><Insets left="20.0" right="20.0"/></padding>
                    <children>
                        <Label prefWidth="20.0" text="⊞" textFill="#b3b3b3"><font><Font size="15.0"/></font></Label>
                        <Button mnemonicParsing="false" onAction="#goBack"
                                style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;"
                                text="Dashboard" textFill="#b3b3b3">
                            <font><Font size="13.0"/></font>
                        </Button>
                    </children>
                </HBox>

                <!-- Films -->
                <HBox alignment="CENTER_LEFT" prefHeight="42.0" spacing="10.0"
                      style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <padding><Insets left="20.0" right="20.0"/></padding>
                    <children>
                        <Label prefWidth="20.0" text="🎬" textFill="#b3b3b3"><font><Font size="13.0"/></font></Label>
                        <Button mnemonicParsing="false" onAction="#goToFilmList"
                                style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;"
                                text="Films" textFill="#b3b3b3">
                            <font><Font size="13.0"/></font>
                        </Button>
                    </children>
                </HBox>

                <!-- Séries -->
                <HBox alignment="CENTER_LEFT" prefHeight="42.0" spacing="10.0"
                      style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <padding><Insets left="20.0" right="20.0"/></padding>
                    <children>
                        <Label prefWidth="20.0" text="📺" textFill="#b3b3b3"><font><Font size="13.0"/></font></Label>
                        <Button mnemonicParsing="false" onAction="#goToSeries"
                                style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;"
                                text="Séries" textFill="#b3b3b3">
                            <font><Font size="13.0"/></font>
                        </Button>
                    </children>
                </HBox>

                <!-- Épisodes -->
                <HBox alignment="CENTER_LEFT" prefHeight="42.0" spacing="10.0"
                      style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <padding><Insets left="20.0" right="20.0"/></padding>
                    <children>
                        <Label prefWidth="20.0" text="▶" textFill="#b3b3b3"><font><Font size="13.0"/></font></Label>
                        <Button mnemonicParsing="false" onAction="#goToEpisodes"
                                style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;"
                                text="Épisodes" textFill="#b3b3b3">
                            <font><Font size="13.0"/></font>
                        </Button>
                    </children>
                </HBox>

                <!-- Abonnés (ACTIVE) -->
                <HBox alignment="CENTER_LEFT" prefHeight="42.0" spacing="10.0"
                      style="-fx-background-color: rgba(229,9,20,0.12); -fx-border-color: #e50914 transparent transparent transparent; -fx-border-width: 0 0 0 3;">
                    <padding><Insets left="20.0" right="20.0"/></padding>
                    <children>
                        <Label prefWidth="20.0" text="👥" textFill="WHITE"><font><Font size="13.0"/></font></Label>
                        <Label text="Abonnés" textFill="WHITE"><font><Font name="System Bold" size="13.0"/></font></Label>
                    </children>
                </HBox>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Footer -->
                <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="10.0"
                      style="-fx-border-color: #2e2e2e; -fx-border-width: 1 0 0 0;">
                    <padding><Insets bottom="12.0" left="20.0" right="20.0" top="12.0"/></padding>
                    <children>
                        <StackPane prefHeight="36.0" prefWidth="36.0"
                                   style="-fx-background-color: #e50914; -fx-background-radius: 18;">
                            <children>
                                <Label text="AD" textFill="WHITE">
                                    <font><Font name="System Bold" size="13.0"/></font>
                                </Label>
                            </children>
                        </StackPane>
                        <VBox spacing="2.0">
                            <children>
                                <Label text="Admin" textFill="WHITE"><font><Font name="System Bold" size="13.0"/></font></Label>
                                <Label text="Super Admin" textFill="#b3b3b3"><font><Font size="11.0"/></font></Label>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button mnemonicParsing="false" onAction="#handleLogout"
                                style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: #b3b3b3;"
                                text="⏻">
                            <font><Font size="18.0"/></font>
                        </Button>
                    </children>
                </HBox>

            </children>
        </VBox>
    </left>

    <!-- ════════════════════════════════════════════════
         TOP — HEADER BAR
    ════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="14.0"
              style="-fx-background-color: #1e1e1e; -fx-border-color: #2e2e2e; -fx-border-width: 0 0 1 0;"
              BorderPane.alignment="CENTER">
            <padding><Insets bottom="10.0" left="28.0" right="28.0" top="10.0"/></padding>
            <children>

                <Label text="Gestion des Abonnés" textFill="WHITE">
                    <font><Font name="System Bold" size="20.0"/></font>
                </Label>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Search -->
                <TextField fx:id="searchField" prefWidth="240.0"
                           promptText="Nom, email, statut..."
                           style="-fx-background-color: #252525; -fx-border-color: #2e2e2e;
                                  -fx-border-radius: 6; -fx-background-radius: 6;
                                  -fx-text-fill: white; -fx-prompt-text-fill: #555555;
                                  -fx-padding: 7 14 7 14;"/>

            </children>
        </HBox>
    </top>

    <!-- ════════════════════════════════════════════════
         CENTER
    ════════════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background: #141414; -fx-border-color: #141414;"
                    BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="20.0" style="-fx-background-color: #141414;" VBox.vgrow="ALWAYS">
                    <padding><Insets bottom="28.0" left="28.0" right="28.0" top="28.0"/></padding>
                    <children>

                        <!-- ── CARTES MÉTRIQUES ──────────────────────────── -->
                        <GridPane hgap="16.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33"/>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33"/>
                            </columnConstraints>
                            <rowConstraints><RowConstraints/></rowConstraints>
                            <children>

                                <!-- Total -->
                                <VBox spacing="8.0" GridPane.columnIndex="0"
                                      style="-fx-background-color: #1e1e1e; -fx-border-color: #2e2e2e;
                                             -fx-border-radius: 10; -fx-background-radius: 10;">
                                    <padding><Insets bottom="18.0" left="20.0" right="20.0" top="18.0"/></padding>
                                    <children>
                                        <Label text="👥  Total Comptes" textFill="#b3b3b3">
                                            <font><Font name="System Bold" size="12.0"/></font>
                                        </Label>
                                        <Label fx:id="totalCountLabel" text="—" textFill="WHITE">
                                            <font><Font name="System Bold" size="38.0"/></font>
                                        </Label>
                                        <Label text="utilisateurs inscrits" textFill="#555555">
                                            <font><Font size="11.0"/></font>
                                        </Label>
                                    </children>
                                </VBox>

                                <!-- Actifs -->
                                <VBox spacing="8.0" GridPane.columnIndex="1"
                                      style="-fx-background-color: #1e1e1e; -fx-border-color: #2e2e2e;
                                             -fx-border-radius: 10; -fx-background-radius: 10;">
                                    <padding><Insets bottom="18.0" left="20.0" right="20.0" top="18.0"/></padding>
                                    <children>
                                        <Label text="✅  Abonnements Actifs" textFill="#46d369">
                                            <font><Font name="System Bold" size="12.0"/></font>
                                        </Label>
                                        <Label fx:id="activeCountLabel" text="—" textFill="#46d369">
                                            <font><Font name="System Bold" size="38.0"/></font>
                                        </Label>
                                        <Label text="abonnements en cours" textFill="#555555">
                                            <font><Font size="11.0"/></font>
                                        </Label>
                                    </children>
                                </VBox>

                                <!-- Expirés -->
                                <VBox spacing="8.0" GridPane.columnIndex="2"
                                      style="-fx-background-color: #1e1e1e; -fx-border-color: #2e2e2e;
                                             -fx-border-radius: 10; -fx-background-radius: 10;">
                                    <padding><Insets bottom="18.0" left="20.0" right="20.0" top="18.0"/></padding>
                                    <children>
                                        <Label text="❌  Abonnements Expirés" textFill="#e50914">
                                            <font><Font name="System Bold" size="12.0"/></font>
                                        </Label>
                                        <Label fx:id="expiredCountLabel" text="—" textFill="#e50914">
                                            <font><Font name="System Bold" size="38.0"/></font>
                                        </Label>
                                        <Label text="nécessitent un renouvellement" textFill="#555555">
                                            <font><Font size="11.0"/></font>
                                        </Label>
                                    </children>
                                </VBox>

                            </children>
                        </GridPane>

                        <!-- ── TABLEAU ──────────────────────────────────── -->
                        <VBox spacing="14.0"
                              style="-fx-background-color: #1e1e1e; -fx-border-color: #2e2e2e;
                                     -fx-border-radius: 10; -fx-background-radius: 10;"
                              VBox.vgrow="ALWAYS">
                            <padding><Insets bottom="20.0" left="22.0" right="22.0" top="20.0"/></padding>
                            <children>

                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Liste des Abonnés" textFill="WHITE">
                                            <font><Font name="System Bold" size="15.0"/></font>
                                        </Label>
                                    </children>
                                </HBox>

                                <TableView fx:id="subscriberTable" prefHeight="380.0" VBox.vgrow="ALWAYS"
                                           style="-fx-background-color: transparent; -fx-border-color: transparent;
                                                  -fx-table-cell-border-color: #2e2e2e;">
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                    </columnResizePolicy>
                                    <columns>
                                        <TableColumn fx:id="colName"    text="NOM"            prefWidth="160"/>
                                        <TableColumn fx:id="colEmail"   text="EMAIL"           prefWidth="220"/>
                                        <TableColumn fx:id="colRole"    text="RÔLE"            prefWidth="80"/>
                                        <TableColumn fx:id="colStart"   text="DÉBUT ABONNEMENT" prefWidth="160"/>
                                        <TableColumn fx:id="colEnd"     text="FIN ABONNEMENT"   prefWidth="160"/>
                                        <TableColumn fx:id="colStatus"  text="STATUT"          prefWidth="110"/>
                                        <TableColumn fx:id="colActions" text="ACTION"          prefWidth="130"/>
                                    </columns>
                                </TableView>

                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
