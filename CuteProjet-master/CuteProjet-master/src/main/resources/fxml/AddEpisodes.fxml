<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="713.0" prefWidth="952.0" style="-fx-background-color: #141414;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.jstream.controller.DashboardAdminController">

    <!-- ═══════════════════════════════════════════════
         TOP — HEADER BAR
    ═══════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="64.0" spacing="14.0" style="-fx-background-color: #1e1e1e; -fx-border-color: #2e2e2e; -fx-border-width: 0 0 1 0;">
            <padding><Insets bottom="12.0" left="28.0" right="28.0" top="12.0" /></padding>
            <children>

                <!-- Bouton retour → goBack() — redirige vers Admin.fxml -->
                <Button mnemonicParsing="false" onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: #b3b3b3; -fx-cursor: hand; -fx-border-color: #2e2e2e; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 16 7 16;" text="← Retour">
                    <font><Font size="13.0" /></font>
                </Button>

                <Separator orientation="VERTICAL" style="-fx-background-color: #2e2e2e;" />

                <VBox spacing="2.0">
                    <children>
                        <Label text="Ajouter un Épisode" textFill="WHITE">
                            <font><Font name="System Bold" size="20.0" /></font>
                        </Label>
                        <Label text="Rattachez un épisode à une série et une saison existantes" textFill="#555555">
                            <font><Font size="12.0" /></font>
                        </Label>
                    </children>
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Label statut feedback -->
                <Label fx:id="statusLabel" text="" textFill="#46d369">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>

            </children>
        </HBox>
    </top>

    <!-- ═══════════════════════════════════════════════
         CENTER — FORMULAIRE
    ═══════════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: #141414; -fx-border-color: #141414;">
            <content>
                <VBox spacing="24.0" style="-fx-background-color: #141414;">
                    <padding><Insets bottom="40.0" left="40.0" right="40.0" top="32.0" /></padding>
                    <children>

                        <!-- ── SECTION 1 : RATTACHEMENT ──────────────────── -->
                        <VBox spacing="16.0" style="-fx-background-color: #1e1e1e; -fx-border-color: #2e2e2e; -fx-border-radius: 12; -fx-background-radius: 12;">
                            <padding><Insets bottom="28.0" left="28.0" right="28.0" top="24.0" /></padding>
                            <children>

                                <!-- En-tête section -->
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <StackPane prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: rgba(229,9,20,0.15); -fx-background-radius: 8;">
                                            <children>
                                                <Label style="-fx-font-size: 14px;" text="🔗" />
                                            </children>
                                        </StackPane>
                                        <Label text="Rattachement" textFill="WHITE">
                                            <font><Font name="System Bold" size="15.0" /></font>
                                        </Label>
                                    </children>
                                </HBox>

                                <Separator style="-fx-background-color: #2e2e2e;" />

                                <!-- Série + Saison -->
                                <GridPane hgap="20.0" vgap="14.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                                    </columnConstraints>
                                    <rowConstraints><RowConstraints /></rowConstraints>
                                    <children>

                                        <!-- Série -->
                                        <VBox spacing="6.0" GridPane.columnIndex="0">
                                            <children>
                                                <Label text="Série *" textFill="#b3b3b3">
                                                    <font><Font name="System Bold" size="12.0" /></font>
                                                </Label>
                                                <ComboBox fx:id="seriesComboBox" maxWidth="Infinity" promptText="Sélectionner une série..." style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-border-color: #2e2e2e; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: white; -fx-padding: 4 8 4 8;" />
                                            </children>
                                        </VBox>

                                        <!-- Saison -->
                                        <VBox spacing="6.0" GridPane.columnIndex="1">
                                            <children>
                                                <Label text="Saison *" textFill="#b3b3b3">
                                                    <font><Font name="System Bold" size="12.0" /></font>
                                                </Label>
                                                <ComboBox fx:id="seasonComboBox" maxWidth="Infinity" promptText="Sélectionner une saison..." style="-fx-font-size: 13px; -fx-background-color: #252525; -fx-border-color: #2e2e2e; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: white; -fx-padding: 4 8 4 8;" />
                                            </children>
                                        </VBox>

                                    </children>
                                </GridPane>

                            </children>
                        </VBox>

                        <!-- ── SECTION 2 : INFORMATIONS DE L'ÉPISODE ────── -->
                        <VBox spacing="16.0" style="-fx-background-color: #1e1e1e; -fx-border-color: #2e2e2e; -fx-border-radius: 12; -fx-background-radius: 12;">
                            <padding><Insets bottom="28.0" left="28.0" right="28.0" top="24.0" /></padding>
                            <children>

                                <!-- En-tête section -->
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <StackPane prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: rgba(229,9,20,0.15); -fx-background-radius: 8;">
                                            <children>
                                                <Label style="-fx-font-size: 14px;" text="🎬" />
                                            </children>
                                        </StackPane>
                                        <Label text="Informations de l'épisode" textFill="WHITE">
                                            <font><Font name="System Bold" size="15.0" /></font>
                                        </Label>
                                    </children>
                                </HBox>

                                <Separator style="-fx-background-color: #2e2e2e;" />

                                <!-- Numéro + Titre + Durée -->
                                <GridPane hgap="20.0" vgap="14.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="15.0" />
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="55.0" />
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="30.0" />
                                    </columnConstraints>
                                    <rowConstraints><RowConstraints /></rowConstraints>
                                    <children>

                                        <!-- Numéro épisode -->
                                        <VBox spacing="6.0" GridPane.columnIndex="0">
                                            <children>
                                                <Label text="N° *" textFill="#b3b3b3">
                                                    <font><Font name="System Bold" size="12.0" /></font>
                                                </Label>
                                                <TextField fx:id="episodeNumberField" promptText="Ex : 1" style="-fx-background-color: #252525; -fx-border-color: #2e2e2e; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: white; -fx-prompt-text-fill: #444444; -fx-padding: 10 14 10 14;">
                                                    <font><Font size="13.0" /></font>
                                                </TextField>
                                            </children>
                                        </VBox>

                                        <!-- Titre épisode -->
                                        <VBox spacing="6.0" GridPane.columnIndex="1">
                                            <children>
                                                <Label text="Titre de l'épisode *" textFill="#b3b3b3">
                                                    <font><Font name="System Bold" size="12.0" /></font>
                                                </Label>
                                                <TextField fx:id="episodeTitleField" promptText="Ex : Le commencement" style="-fx-background-color: #252525; -fx-border-color: #2e2e2e; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: white; -fx-prompt-text-fill: #444444; -fx-padding: 10 14 10 14;">
                                                    <font><Font size="13.0" /></font>
                                                </TextField>
                                            </children>
                                        </VBox>

                                        <!-- Durée -->
                                        <VBox spacing="6.0" GridPane.columnIndex="2">
                                            <children>
                                                <Label text="Durée (min) *" textFill="#b3b3b3">
                                                    <font><Font name="System Bold" size="12.0" /></font>
                                                </Label>
                                                <TextField fx:id="episodeDurationField" promptText="Ex : 45" style="-fx-background-color: #252525; -fx-border-color: #2e2e2e; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: white; -fx-prompt-text-fill: #444444; -fx-padding: 10 14 10 14;">
                                                    <font><Font size="13.0" /></font>
                                                </TextField>
                                            </children>
                                        </VBox>

                                    </children>
                                </GridPane>

                                <!-- Description épisode -->
                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="Description" textFill="#b3b3b3">
                                            <font><Font name="System Bold" size="12.0" /></font>
                                        </Label>
                                        <TextArea fx:id="episodeDescriptionField" prefRowCount="4" promptText="Résumé court de l'épisode..." style="-fx-background-color: #252525; -fx-border-color: #2e2e2e; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: white; -fx-prompt-text-fill: #444444; -fx-padding: 10 14 10 14;" wrapText="true">
                                            <font><Font size="13.0" /></font>
                                        </TextArea>
                                    </children>
                                </VBox>

                            </children>
                        </VBox>

                        <!-- ── SECTION 3 : MÉDIAS ─────────────────────────── -->
                        <VBox spacing="16.0" style="-fx-background-color: #1e1e1e; -fx-border-color: #2e2e2e; -fx-border-radius: 12; -fx-background-radius: 12;">
                            <padding><Insets bottom="28.0" left="28.0" right="28.0" top="24.0" /></padding>
                            <children>

                                <!-- En-tête section -->
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <StackPane prefHeight="30.0" prefWidth="30.0" style="-fx-background-color: rgba(229,9,20,0.15); -fx-background-radius: 8;">
                                            <children>
                                                <Label style="-fx-font-size: 14px;" text="🖼" />
                                            </children>
                                        </StackPane>
                                        <Label text="Médias" textFill="WHITE">
                                            <font><Font name="System Bold" size="15.0" /></font>
                                        </Label>
                                    </children>
                                </HBox>

                                <Separator style="-fx-background-color: #2e2e2e;" />

                                <!-- URL Vidéo + URL Miniature -->
                                <GridPane hgap="20.0" vgap="14.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                                        <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0" />
                                    </columnConstraints>
                                    <rowConstraints><RowConstraints /></rowConstraints>
                                    <children>

                                        <!-- URL Vidéo -->
                                        <VBox spacing="6.0" GridPane.columnIndex="0">
                                            <children>
                                                <Label text="URL Vidéo *" textFill="#b3b3b3">
                                                    <font><Font name="System Bold" size="12.0" /></font>
                                                </Label>
                                                <TextField fx:id="episodeVideoUrlField" promptText="https://..." style="-fx-background-color: #252525; -fx-border-color: #2e2e2e; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: white; -fx-prompt-text-fill: #444444; -fx-padding: 10 14 10 14;">
                                                    <font><Font size="13.0" /></font>
                                                </TextField>
                                            </children>
                                        </VBox>

                                        <!-- URL Miniature -->
                                        <VBox spacing="6.0" GridPane.columnIndex="1">
                                            <children>
                                                <Label text="URL Miniature (thumbnail)" textFill="#b3b3b3">
                                                    <font><Font name="System Bold" size="12.0" /></font>
                                                </Label>
                                                <TextField fx:id="episodeThumbnailUrlField" promptText="https://..." style="-fx-background-color: #252525; -fx-border-color: #2e2e2e; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: white; -fx-prompt-text-fill: #444444; -fx-padding: 10 14 10 14;">
                                                    <font><Font size="13.0" /></font>
                                                </TextField>
                                            </children>
                                        </VBox>

                                    </children>
                                </GridPane>

                            </children>
                        </VBox>

                        <!-- ── BARRE D'ACTIONS ────────────────────────────── -->
                        <HBox alignment="CENTER_RIGHT" spacing="12.0">
                            <children>

                                <!-- Annuler → goBack() vers Admin.fxml -->
                                <Button mnemonicParsing="false" onAction="#goBack" style="-fx-background-color: transparent; -fx-text-fill: #b3b3b3; -fx-cursor: hand; -fx-border-color: #2e2e2e; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 11 28 11 28;" text="Annuler">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Button>

                                <!-- Réinitialiser → handleReset() -->
                                <Button mnemonicParsing="false" onAction="#handleReset" style="-fx-background-color: #252525; -fx-text-fill: #b3b3b3; -fx-cursor: hand; -fx-border-color: #2e2e2e; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 11 28 11 28;" text="↺  Réinitialiser">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Button>

                                <!-- Ajouter l'épisode → handleAddEpisode() -->
                                <Button mnemonicParsing="false" onAction="#handleAddEpisode" style="-fx-background-color: #e50914; -fx-text-fill: white; -fx-cursor: hand; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 11 32 11 32;" text="＋  Ajouter l'Épisode">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Button>

                            </children>
                        </HBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
