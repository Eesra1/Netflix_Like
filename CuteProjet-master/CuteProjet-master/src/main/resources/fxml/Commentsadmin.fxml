<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane minHeight="600.0" minWidth="900.0" prefHeight="700.0" prefWidth="1200.0"
            style="-fx-background-color: #141414;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.jstream.controller.CommentsAdminController">

    <!-- ══ SIDEBAR ══ -->
    <left>
        <VBox minWidth="220.0" prefWidth="220.0"
              style="-fx-background-color: #1e1e1e; -fx-border-color: #2e2e2e; -fx-border-width: 0 1 0 0;"
              BorderPane.alignment="TOP_LEFT">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="64.0"
                      style="-fx-border-color: #2e2e2e; -fx-border-width: 0 0 1 0;">
                    <padding><Insets bottom="16" left="24" right="24" top="16"/></padding>
                    <Label text="Movix" textFill="#e50914">
                        <font><Font name="System Bold" size="26"/></font>
                    </Label>
                </HBox>

                <Label style="-fx-padding: 18 14 6 14;" text="PRINCIPAL" textFill="#555555">
                    <font><Font name="System Bold" size="10"/></font>
                </Label>

                <!-- Dashboard -->
                <HBox alignment="CENTER_LEFT" prefHeight="42" spacing="10"
                      style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <padding><Insets left="20" right="20"/></padding>
                    <Label prefWidth="20" text="⊞" textFill="#b3b3b3"><font><Font size="15"/></font></Label>
                    <Button mnemonicParsing="false" onAction="#goBack"
                            style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;"
                            text="Dashboard" textFill="#b3b3b3">
                        <font><Font size="13"/></font>
                    </Button>
                </HBox>

                <!-- Films -->
                <HBox alignment="CENTER_LEFT" prefHeight="42" spacing="10"
                      style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <padding><Insets left="20" right="20"/></padding>
                    <Label prefWidth="20" text="🎬" textFill="#b3b3b3"><font><Font size="13"/></font></Label>
                    <Button mnemonicParsing="false" onAction="#goToFilmList"
                            style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;"
                            text="Films" textFill="#b3b3b3">
                        <font><Font size="13"/></font>
                    </Button>
                </HBox>

                <!-- Séries -->
                <HBox alignment="CENTER_LEFT" prefHeight="42" spacing="10"
                      style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <padding><Insets left="20" right="20"/></padding>
                    <Label prefWidth="20" text="📺" textFill="#b3b3b3"><font><Font size="13"/></font></Label>
                    <Button mnemonicParsing="false" onAction="#goToSeries"
                            style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;"
                            text="Séries" textFill="#b3b3b3">
                        <font><Font size="13"/></font>
                    </Button>
                </HBox>

                <!-- Abonnés -->
                <HBox alignment="CENTER_LEFT" prefHeight="42" spacing="10"
                      style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <padding><Insets left="20" right="20"/></padding>
                    <Label prefWidth="20" text="👥" textFill="#b3b3b3"><font><Font size="13"/></font></Label>
                    <Button mnemonicParsing="false" onAction="#goToSubscribers"
                            style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;"
                            text="Abonnés" textFill="#b3b3b3">
                        <font><Font size="13"/></font>
                    </Button>
                </HBox>

                <!-- Commentaires (ACTIF) -->
                <HBox alignment="CENTER_LEFT" prefHeight="42" spacing="10"
                      style="-fx-background-color: rgba(229,9,20,0.12); -fx-border-color: #e50914 transparent transparent transparent; -fx-border-width: 0 0 0 3;">
                    <padding><Insets left="20" right="20"/></padding>
                    <Label prefWidth="20" text="💬" textFill="WHITE"><font><Font size="13"/></font></Label>
                    <Label text="Commentaires" textFill="WHITE"><font><Font name="System Bold" size="13"/></font></Label>
                </HBox>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Footer -->
                <HBox alignment="CENTER_LEFT" prefHeight="60" spacing="10"
                      style="-fx-border-color: #2e2e2e; -fx-border-width: 1 0 0 0;">
                    <padding><Insets bottom="12" left="20" right="20" top="12"/></padding>
                    <StackPane prefHeight="36" prefWidth="36"
                               style="-fx-background-color: #e50914; -fx-background-radius: 18;">
                        <Label text="AD" textFill="WHITE"><font><Font name="System Bold" size="13"/></font></Label>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="Admin" textFill="WHITE"><font><Font name="System Bold" size="13"/></font></Label>
                        <Label text="Super Admin" textFill="#b3b3b3"><font><Font size="11"/></font></Label>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button mnemonicParsing="false" onAction="#handleLogout"
                            style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: #b3b3b3;"
                            text="⏻"><font><Font size="18"/></font>
                    </Button>
                </HBox>
            </children>
        </VBox>
    </left>

    <!-- ══ HEADER ══ -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60" spacing="14"
              style="-fx-background-color: #1e1e1e; -fx-border-color: #2e2e2e; -fx-border-width: 0 0 1 0;"
              BorderPane.alignment="CENTER">
            <padding><Insets bottom="10" left="28" right="28" top="10"/></padding>
            <Label text="Gestion des Commentaires" textFill="WHITE">
                <font><Font name="System Bold" size="20"/></font>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" prefWidth="260"
                       promptText="Rechercher un commentaire, type..."
                       style="-fx-background-color: #252525; -fx-border-color: #2e2e2e;
                              -fx-border-radius: 6; -fx-background-radius: 6;
                              -fx-text-fill: white; -fx-prompt-text-fill: #555555;
                              -fx-padding: 7 14 7 14;"/>
        </HBox>
    </top>

    <!-- ══ CENTER ══ -->
    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background: #141414; -fx-border-color: #141414;">
            <content>
                <VBox spacing="20" style="-fx-background-color: #141414;" VBox.vgrow="ALWAYS">
                    <padding><Insets bottom="28" left="28" right="28" top="28"/></padding>

                    <!-- Métriques -->
                    <GridPane hgap="16">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                        </columnConstraints>
                        <rowConstraints><RowConstraints/></rowConstraints>

                        <!-- Total -->
                        <VBox spacing="8" GridPane.columnIndex="0"
                              style="-fx-background-color: #1e1e1e; -fx-border-color: #2e2e2e;
                                     -fx-border-radius: 10; -fx-background-radius: 10;">
                            <padding><Insets bottom="18" left="20" right="20" top="18"/></padding>
                            <Label text="💬  Total Commentaires" textFill="#b3b3b3">
                                <font><Font name="System Bold" size="12"/></font>
                            </Label>
                            <Label fx:id="totalCountLabel" text="—" textFill="WHITE">
                                <font><Font name="System Bold" size="38"/></font>
                            </Label>
                            <Label text="commentaires publiés" textFill="#555555">
                                <font><Font size="11"/></font>
                            </Label>
                        </VBox>

                        <!-- Signalés -->
                        <VBox spacing="8" GridPane.columnIndex="1"
                              style="-fx-background-color: #1e1e1e; -fx-border-color: #2e2e2e;
                                     -fx-border-radius: 10; -fx-background-radius: 10;">
                            <padding><Insets bottom="18" left="20" right="20" top="18"/></padding>
                            <Label text="⚠️  Commentaires Signalés" textFill="#ff9800">
                                <font><Font name="System Bold" size="12"/></font>
                            </Label>
                            <Label fx:id="flaggedCountLabel" text="—" textFill="#ff9800">
                                <font><Font name="System Bold" size="38"/></font>
                            </Label>
                            <Label text="nécessitent une modération" textFill="#555555">
                                <font><Font size="11"/></font>
                            </Label>
                        </VBox>
                    </GridPane>

                    <!-- Tableau -->
                    <VBox spacing="14"
                          style="-fx-background-color: #1e1e1e; -fx-border-color: #2e2e2e;
                                 -fx-border-radius: 10; -fx-background-radius: 10;"
                          VBox.vgrow="ALWAYS">
                        <padding><Insets bottom="20" left="22" right="22" top="20"/></padding>

                        <Label text="Tous les commentaires" textFill="WHITE">
                            <font><Font name="System Bold" size="15"/></font>
                        </Label>

                        <TableView fx:id="commentsTable" prefHeight="420" VBox.vgrow="ALWAYS"
                                   style="-fx-background-color: transparent; -fx-border-color: transparent;
                                          -fx-table-cell-border-color: #2e2e2e;">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colId"        text="ID"        prefWidth="50"/>
                                <TableColumn fx:id="colUser"      text="UTILISATEUR" prefWidth="120"/>
                                <TableColumn fx:id="colType"      text="TYPE"      prefWidth="80"/>
                                <TableColumn fx:id="colContentId" text="CONTENU #" prefWidth="80"/>
                                <TableColumn fx:id="colContent"   text="COMMENTAIRE" prefWidth="300"/>
                                <TableColumn fx:id="colDate"      text="DATE"      prefWidth="140"/>
                                <TableColumn fx:id="colFlagged"   text="STATUT"    prefWidth="100"/>
                                <TableColumn fx:id="colActions"   text="ACTIONS"   prefWidth="180"/>
                            </columns>
                        </TableView>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
